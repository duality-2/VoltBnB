{
  "rules": {
    "sessions": {
      "$bookingId": {
        // Both renter and host for a booking can read the live session
        ".read": "auth != null && (data.child('renterUid').val() === auth.uid || data.child('hostUid').val() === auth.uid)",
        
        // Only the host for the booking can write/create the session
        ".write": "auth != null && (!data.exists() || data.child('hostUid').val() === auth.uid)"
      }
    }
  }
}
