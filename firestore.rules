rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users: owner-only profile access
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Chargers: public read, owner-managed write via hostUid
    match /chargers/{chargerId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.hostUid == request.auth.uid;

      allow update, delete: if request.auth != null
        && resource.data.hostUid == request.auth.uid
        && request.resource.data.hostUid == resource.data.hostUid;
    }

    // Bookings: renter creates, renter/host can read and update
    match /bookings/{bookingId} {
      allow read: if request.auth != null
        && (resource.data.renterUid == request.auth.uid
          || resource.data.hostUid == request.auth.uid);

      allow create: if request.auth != null
        && request.resource.data.renterUid == request.auth.uid;

      allow update: if request.auth != null
        && (resource.data.renterUid == request.auth.uid
          || resource.data.hostUid == request.auth.uid);

      allow delete: if request.auth != null
        && request.auth.uid == resource.data.renterUid
        && resource.data.status == 'pending';
    }

    // Reviews: authenticated users can create their own review records
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.renterUid == request.auth.uid;
      allow update, delete: if false;
    }

    // Notifications: owner-only reads
    match /notifications/{userId}/items/{itemId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }
  }
}
