rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Function to get the current user's role
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Ensure the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Ensure the request is from the owner of the document
    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // Never allow password or password-hash style fields in Firestore.
    // Passwords are securely managed by Firebase Authentication.
    function hasNoCredentialFields(data) {
      return !data.keys().hasAny([
        'password',
        'passwordHash',
        'passwordEncrypted',
        'passwordSalt',
        'passwordCiphertext'
      ]);
    }

    match /users/{userId} {
      // Users can only read their own profile.
      allow read: if isAuthenticated() && isOwner(userId);

      // Owner can create their own document, without credential fields.
      allow create: if isAuthenticated() && isOwner(userId)
        && request.resource.data.uid == userId
        && hasNoCredentialFields(request.resource.data);

      // Owner can update profile fields, but cannot mutate identity primitives
      // or write credential fields.
      allow update: if isAuthenticated() && isOwner(userId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
        && request.resource.data.createdAt == resource.data.createdAt
        && hasNoCredentialFields(request.resource.data);

      // Owner can delete own profile document.
      allow delete: if isAuthenticated() && isOwner(userId);
    }

    match /chargers/{chargerId} {
      // Anyone authenticated can read chargers (for the map discovery)
      allow read: if isAuthenticated();
      // Only hosts can create a new charger, and it must belong to them
      allow create: if isAuthenticated() && getUserRole() == 'host' && request.resource.data.hostUid == request.auth.uid;
      // Only the host who owns the charger can update/delete it
      allow update, delete: if isAuthenticated() && getUserRole() == 'host' && resource.data.hostUid == request.auth.uid;
    }

    match /bookings/{bookingId} {
      // Renter can read their own bookings.
      // Host can read bookings for their chargers.
      // Any authenticated user can read bookings to check charger availability (overlap detection).
      allow read: if isAuthenticated();

      // Renters create bookings (initially pending)
      allow create: if isAuthenticated() && request.resource.data.renterUid == request.auth.uid;

      // Both renter and host can update (e.g. host accepts/rejects, status transitions)
      allow update: if isAuthenticated() && (
        resource.data.renterUid == request.auth.uid ||
        resource.data.hostUid == request.auth.uid
      );

      // Allow renter to delete if pending (cancelled)
      allow delete: if isAuthenticated() && resource.data.renterUid == request.auth.uid && resource.data.status == 'pending';
    }

    match /reviews/{reviewId} {
      // Anyone authenticated can read reviews
      allow read: if isAuthenticated();
      // Only renters can leave reviews, and it must be for a booking they made
      allow create: if isAuthenticated() && request.resource.data.renterUid == request.auth.uid;
      // No updates or deletes to reviews by clients
      allow update, delete: if false;
    }

    // Top-level notifications collection (flat, not subcollection)
    match /notifications/{notificationId} {
      // Users can only read and mark-as-read their own notifications
      allow read: if isAuthenticated() && resource.data.userUid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userUid == request.auth.uid;
      allow create, delete: if false; // Created/deleted by backend only
    }
  }
}
